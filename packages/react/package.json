{
  "name": "@kenos-ui/react",
  "version": "0.3.1",
  "description": "Kenos UI headless primitives for React — aggregator",
  "repository": {
    "type": "git",
    "url": "https://github.com/allysontsoares/kenos-ui",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kenos-ui/react-combobox": "workspace:*",
    "@kenos-ui/react-datepicker": "workspace:*",
    "@kenos-ui/react-select": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}