{
  "name": "@kenos-ui/react-datepicker",
  "version": "0.3.2",
  "description": "Headless date & scheduling primitives for React — Kenos UI DatePicker",
  "repository": {
    "type": "git",
    "url": "https://github.com/allysontsoares/kenos-ui",
    "directory": "packages/datepicker"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "storybook": "BROWSER=xdg-open storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@kenos-ui/utils": "workspace:*",
    "timescape": "^0.8.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.0.0",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-onboarding": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "^8.0.0",
    "@storybook/test": "8.6.18",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "8.6.18",
    "tsup": "^8.0.0",
    "typescript": "^6.0.0",
    "axe-core": "^4.10.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vitest-axe": "^0.1.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}