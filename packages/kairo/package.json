{
  "name": "@at5/kairo",
  "version": "0.2.4",
  "description": "Deprecated compatibility shim — re-exports @kenos-ui/react-datepicker. Migrate to @kenos-ui/react-datepicker.",
  "homepage": "https://kenos.at5.dev",
  "keywords": [
    "deprecated",
    "date-picker",
    "react",
    "kenos-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/allysontsoares/primitives",
    "directory": "packages/kairo"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kenos-ui/react-datepicker": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
